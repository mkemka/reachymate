# Reachy Mini Conversation App – copy to .env and fill in values
# Required: OpenAI key for realtime API (or enter in app settings at http://127.0.0.1:7860/)

OPENAI_API_KEY=

# Optional overrides
# MODEL_NAME=gpt-realtime
# HF_HOME=./cache
# HF_TOKEN=
# LOCAL_VISION_MODEL=HuggingFaceTB/SmolVLM2-2.2B-Instruct
# REACHY_MINI_CUSTOM_PROFILE=receptionist
