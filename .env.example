# Reachy Mini Conversation App – copy to .env and fill in values
# Required: OpenAI key for realtime API (or enter in app settings at http://127.0.0.1:7860/)

OPENAI_API_KEY=

# Optional overrides
# MODEL_NAME=gpt-realtime
# HF_HOME=./cache
# HF_TOKEN=
# LOCAL_VISION_MODEL=HuggingFaceTB/SmolVLM2-2.2B-Instruct
# REACHY_MINI_CUSTOM_PROFILE=receptionist

# ── Receptionist mode ────────────────────────────────────────────────────────
# Enable with: pip install '.[receptionist]' and run with --receptionist
# Whisper requires ffmpeg on PATH: https://ffmpeg.org/download.html
# RECEPTIONIST_MODE=1

# Face detection — Ultralytics YOLO26x (best accuracy)
# https://platform.ultralytics.com/ultralytics/yolo26/yolo26x
# Alternatives: yolo26n.pt (fastest), hf (HuggingFace face-specific detector)
# YOLO_FACE_MODEL=yolo26x.pt

# Face recognition — InsightFace buffalo_l (best open-source recognition)
# https://www.insightface.ai/
# INSIGHTFACE_MODEL_NAME=buffalo_l

# Voice recognition — OpenAI Whisper (English-only variant, faster)
# https://github.com/openai/whisper
# Options: tiny.en  base.en  small.en  medium.en  turbo  large
# turbo is best speed/accuracy tradeoff if a GPU is available
# WHISPER_MODEL=base.en

# Matching thresholds
# RECEPTIONIST_FACE_THRESHOLD=0.35
# RECEPTIONIST_VOICE_THRESHOLD=0.72
# FACE_CONFIDENCE_HIGH_THRESHOLD=0.90

# Ledger & check-in controller
# CHECK_IN_COST_POINTS=1
# LEDGER_INITIAL_BALANCE=100

# Session & audio buffer
# RECEPTIONIST_SESSION_TTL_S=300
# RECEPTIONIST_AUDIO_BUFFER_S=6
# RECEPTIONIST_WAKE_PHRASES=hey reachy,hello reachy,reachy
